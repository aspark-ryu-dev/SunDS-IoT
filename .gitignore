# --- whitelist: track only the two IoT projects + shared/ + repo-root meta ---
/*
!/.gitignore
!/README.md
!/IoT-Dashboard/
!/IoT-Data/
!/shared/

# local assistant/editor state
**/.claude/

# --- generated copies of shared/ (synced by *-push.ps1, do not commit) ---
IoT-Dashboard/_shared_*.gs
IoT-Data/_shared_*.gs

# --- caches / build artifacts inside the tracked folders ---
*.bak
.npm-cache/
.npm-cache-push/
**/.npm-cache/
**/.npm-cache-push/
node_modules/
**/node_modules/

.DS_Store
Thumbs.db

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

.env
.env.*
!.env.example
