# --- whitelist: track only the two IoT projects (and a couple of repo-root files) ---
/*
!/.gitignore
!/README.md
!/IoT-Dashboard/
!/IoT-Data/

# --- caches / build artifacts inside the tracked folders ---
.npm-cache/
.npm-cache-push/
**/.npm-cache/
**/.npm-cache-push/
node_modules/
**/node_modules/

.DS_Store
Thumbs.db

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

.env
.env.*
!.env.example
