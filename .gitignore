# --- whitelist: track active projects, release tooling, and project rules ---
/*
!/.gitignore
!/README.md
!/package.json
!/IoT-Dashboard/
!/IoT-Data/
!/shared/
!/tools/
!/tools/**
!/.skills/
!/.skills/sunds-iot-gas/
!/.skills/sunds-iot-gas/**

# local assistant/editor state
**/.claude/
.local/
.tmp-icons/

# generated copies of shared/ (synced by the release tool, do not commit)
IoT-Dashboard/_shared_*.gs
IoT-Data/_shared_*.gs

# --- caches / build artifacts inside the tracked folders ---
*.bak
.npm-cache/
.npm-cache-push/
**/.npm-cache/
**/.npm-cache-push/
node_modules/
**/node_modules/

.DS_Store
Thumbs.db

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

.env
.env.*
!.env.example
.clasprc.json
/.clasp.json
*.key
*.pem
